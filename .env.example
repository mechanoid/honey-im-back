# Comma-separated list of all family members tracked by the app.
# Copy this file to .env and adjust for your household.
FAMILY_MEMBERS=falk,leni,sarah,paul

# Optional API secret. When set, every request must include:
#   Authorization: ApiKey-v1: <your-secret>
# Leave unset to run without authentication (e.g. on a trusted local network).
# API_SECRET=my-little-secret
