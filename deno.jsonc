{
  "imports": {
    "@db/redis": "jsr:@db/redis@^0.41.2",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
  },
  "tasks": {
    "dev": "deno run -P=run main.ts",
    "start": "deno run -P=run main.ts",
  },
  "permissions": {
    "run": {
      "net": true,
      "env": true,
      "read": [".env"],
    },
  },
}
